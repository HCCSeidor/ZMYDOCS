<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:html="http://www.w3.org/1999/xhtml">

	<Dialog
		id="ShowPDF"
		title=""
		contentHeight="85vh"
		contentWidth="900px"
		draggable="true"
		resizable="true"
		verticalScrolling="false"
		horizontalScrolling="false"
		showHeader="true"
		endButton="false">

		<customHeader>
			<Bar>
				<contentRight>
					<Button
						icon="sap-icon://decline"
						type="Transparent"
						press="onCloseShowPDF"
						tooltip="Cerrar" />
				</contentRight>
			</Bar>
		</customHeader>

		<content>
			<html:iframe
				id="pdfFrame"
				style="display:none; border:none;"
				width="100%"
				height="100%" />
		</content>

	</Dialog>

</core:FragmentDefinition>
